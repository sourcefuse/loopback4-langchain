# Support Bot Environment Variables

# LangChain Configuration
GROQ_API_KEY=your-groq-api-key-here

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=86400
REDIS_PREFIX=langchain:chat_history:

# Note: If REDIS_URL is provided, it takes precedence over individual connection parameters