{
  "name": "loopback4-langchain",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "lb-tsc",
    "build:watch": "lb-tsc --watch",
    "clean": "lb-clean dist *.tsbuildinfo .eslintcache",
    "lint": "npm run prettier:check && npm run eslint",
    "lint:fix": "npm run eslint:fix && npm run prettier:fix",
    "prettier:cli": "lb-prettier \"**/*.ts\" \"**/*.js\"",
    "prettier:check": "npm run prettier:cli -- -l",
    "prettier:fix": "npm run prettier:cli -- --write",
    "eslint": "lb-eslint --report-unused-disable-directives .",
    "eslint:fix": "npm run eslint -- --fix",
    "prepare": "husky install",
    "pretest": "npm run clean && npm run build",
    "test": "lb-mocha --allow-console-logs \"dist/__tests__\"",
    "posttest": "npm run lint",
    "prepublishOnly": "npm run test",
    "coverage": "nyc npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sourcefuse/loopback4-langchain.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/sourcefuse/loopback4-langchain/issues"
  },
  "homepage": "https://github.com/sourcefuse/loopback4-langchain#readme",
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@loopback/build": "^11.0.11",
    "@loopback/eslint-config": "^15.0.5",
    "@loopback/testlab": "^7.0.12",
    "@types/node": "^22.14.1",
    "commitizen": "^4.3.1",
    "cz-customizable": "^7.4.0",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "nyc": "^17.1.0",
    "sinon": "^20.0.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@langchain/groq": "^0.2.2",
    "@loopback/boot": "^7.0.13",
    "@loopback/core": "^6.1.10",
    "@loopback/rest": "^14.0.13",
    "langchain": "^0.3.23"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-customizable"
    }
  }
}
