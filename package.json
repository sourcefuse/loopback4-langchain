{
  "name": "loopback4-langchain-monorepo",
  "version": "1.0.0",
  "description": "Monorepo for loopback4-langchain",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "prepare": "husky install",
    "lint": "npm run prettier:check && npm run eslint",
    "lint:fix": "npm run eslint:fix && npm run prettier:fix",
    "prettier:cli": "prettier \"**/*.ts\" \"**/*.js\"",
    "prettier:check": "npm run prettier:cli -- --check",
    "prettier:fix": "npm run prettier:cli -- --write",
    "eslint": "eslint --ext .js,.ts .",
    "eslint:fix": "npm run eslint -- --fix",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "clean": "npm run clean --workspaces",
    "dev": "npm run dev --workspace=support-bot",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sourcefuse/loopback4-langchain.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/sourcefuse/loopback4-langchain/issues"
  },
  "homepage": "https://github.com/sourcefuse/loopback4-langchain#readme",
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@loopback/build": "^11.0.11",
    "@loopback/eslint-config": "^15.0.5",
    "@loopback/testlab": "^7.0.12",
    "@types/node": "^22.14.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "commitizen": "^4.3.1",
    "cz-customizable": "^7.4.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "nodemon": "^3.0.1",
    "nyc": "^17.1.0",
    "sinon": "^20.0.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@langchain/core": "^0.3.57",
    "@langchain/groq": "^0.2.2",
    "@langchain/langgraph": "^0.2.73",
    "@loopback/boot": "^7.0.13",
    "@loopback/core": "^6.1.10",
    "@loopback/rest": "^14.0.13",
    "langchain": "^0.3.23"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-customizable"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
