{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LangChain Runnable Schema",
  "description": "Schema for LangChain Runnable objects",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "description": "The type of the runnable",
      "enum": ["llm", "chat_model", "tool", "chain", "retriever", "output_parser", "prompt", "document_transformer"]
    },
    "id": {
      "type": "string",
      "description": "Unique identifier for the runnable"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name for the runnable"
    },
    "description": {
      "type": "string",
      "description": "Description of what the runnable does"
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata for the runnable"
    },
    "config": {
      "type": "object",
      "description": "Configuration for the runnable"
    },
    "lc": {
      "type": "object",
      "description": "LangChain serialization information",
      "properties": {
        "type": {
          "type": "string",
          "description": "The type identifier for serialization"
        },
        "id": {
          "type": ["string", "array"],
          "description": "The identifier for serialization"
        },
        "kwargs": {
          "type": "object",
          "description": "Constructor arguments for serialization"
        }
      },
      "required": ["type"]
    }
  },
  "required": ["type"],
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "properties": { "type": { "const": "llm" } }
      },
      "then": {
        "properties": {
          "config": {
            "type": "object",
            "properties": {
              "model": { "type": "string" },
              "temperature": { "type": "number" },
              "max_tokens": { "type": "integer" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "chat_model" } }
      },
      "then": {
        "properties": {
          "config": {
            "type": "object",
            "properties": {
              "model": { "type": "string" },
              "temperature": { "type": "number" },
              "max_tokens": { "type": "integer" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "tool" } }
      },
      "then": {
        "properties": {
          "config": {
            "type": "object",
            "properties": {
              "schema": { "type": "object" },
              "func": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "chain" } }
      },
      "then": {
        "properties": {
          "config": {
            "type": "object",
            "properties": {
              "steps": { 
                "type": "array",
                "items": { "type": "object" }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "retriever" } }
      },
      "then": {
        "properties": {
          "config": {
            "type": "object",
            "properties": {
              "search_type": { "type": "string" },
              "search_kwargs": { "type": "object" }
            }
          }
        }
      }
    }
  ]
}